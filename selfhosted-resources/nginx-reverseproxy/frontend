# ============================================================================
# Reverse-proxy konfigurace pro frontend Engel Gematex (self-hosted, HTTPS)
# Tento soubor obsahuje:
#   - HTTP→HTTPS redirect
#   - HSTS, CSP, X-Frame-Options a další security hlavičky
#   - Rate limiting (obecný + striktní pro /auth/v1/*)
#   - Ochranu proti brute-force na auth endpoints
# Umístění na hostiteli: /etc/nginx/sites-available/frontend
# ============================================================================

# === Rate-limit zóny (musí být v http {} kontextu = mimo server bloky) ===
# Vložte do nginx.conf v sekci http { ... } nebo do conf.d/rate-limits.conf:
#
#   limit_req_zone $binary_remote_addr zone=auth_strict:10m rate=5r/m;
#   limit_req_zone $binary_remote_addr zone=auth_burst:10m rate=10r/s;
#   limit_req_zone $binary_remote_addr zone=api_general:10m rate=30r/s;
#   limit_conn_zone $binary_remote_addr zone=conn_per_ip:10m;

server {
    server_name frontend.domain;

    listen 443 ssl http2; # managed by Certbot
    listen [::]:443 ssl http2; # managed by Certbot

    ssl_certificate /etc/letsencrypt/live/frontend.domain/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/frontend.domain/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # === Modern SSL settings ===
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;

    # === Bezpečnostní hlavičky ===
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.frontend.domain wss://api.frontend.domain; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests" always;
    server_tokens off;

    # Skryje upstream identifikaci
    proxy_hide_header X-Powered-By;
    proxy_hide_header Server;

    # Limit počtu souběžných spojení per IP
    limit_conn conn_per_ip 50;

    # Standardní proxy hlavičky
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Port 443;
    proxy_set_header X-Forwarded-Host $host:443;

    # WebSocket podpora
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    # === Frontend SPA ===
    location / {
        limit_req zone=api_general burst=60 nodelay;
        proxy_pass http://127.0.0.1:8087/;
        proxy_read_timeout 36000s;
    }
}

# === HTTP → HTTPS redirect (vynucené HTTPS) ===
server {
    if ($host = frontend.domain) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    server_name frontend.domain;
    return 404;
}
