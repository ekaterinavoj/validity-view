# ============================================================================
# Reverse-proxy pro Supabase API (Kong) — self-hosted
# Speciální blok pro /auth/v1/* s přísným rate limitingem a brute-force ochranou.
# Umístění: /etc/nginx/sites-available/frontend-api
# ============================================================================

# Předpokládá rate-limit zóny definované v http { } kontextu hlavního nginx.conf:
#   limit_req_zone $binary_remote_addr zone=auth_strict:10m rate=5r/m;   # 5 req/min — striktní pro signin
#   limit_req_zone $binary_remote_addr zone=auth_burst:10m rate=10r/s;   # 10 req/s — token refresh atp.
#   limit_req_zone $binary_remote_addr zone=api_general:10m rate=30r/s;
#   limit_conn_zone $binary_remote_addr zone=conn_per_ip:10m;

server {
    server_name frontend.domain;

    listen [::]:443 ssl http2; # managed by Certbot
    listen 443 ssl http2; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/frontend.domain/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/frontend.domain/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # === Modern TLS ===
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_stapling on;
    ssl_stapling_verify on;

    # === Bezpečnostní hlavičky ===
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;
    server_tokens off;
    proxy_hide_header X-Powered-By;
    proxy_hide_header Server;

    # Globální limity
    limit_conn conn_per_ip 100;
    client_max_body_size 50M;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    # =========================================================================
    # PŘÍSNÝ rate-limit pro signin/signup (anti brute-force)
    # 5 požadavků/minutu na IP s burst 3 = max ~8 pokusů, pak HTTP 429
    # =========================================================================
    location ~ ^/auth/v1/(token|signup|recover|otp|magiclink) {
        limit_req zone=auth_strict burst=3 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8091;
        proxy_read_timeout 30s;
    }

    # =========================================================================
    # Ostatní auth endpoints (refresh token, user info) — mírnější limit
    # =========================================================================
    location ~ ^/auth/v1/ {
        limit_req zone=auth_burst burst=20 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:8091;
        proxy_read_timeout 30s;
    }

    # =========================================================================
    # Storage / REST / Functions / Realtime — obecný rate limit
    # =========================================================================
    location / {
        limit_req zone=api_general burst=60 nodelay;
        proxy_pass http://127.0.0.1:8091/;
        proxy_read_timeout 36000s;
    }
}

# === HTTP → HTTPS redirect ===
server {
    if ($host = frontend.domain) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    server_name frontend.domain;
    return 404;
}
